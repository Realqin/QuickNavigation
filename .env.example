# Docker Compose 本地默认：启用 Redpanda Console（profile redpanda）
# 线上 ARM 部署请勿设置 redpanda profile，改用 docker-compose.prod.yml 中的 kafka-ui
COMPOSE_PROFILES=redpanda

# Kafka 控制台配置目录（挂载到 backend 与 console 容器的 /config）
KAFKA_CONFIG_HOST_DIR=./docker/redpanda/data

# Kafka 控制台实现：redpanda（本地）| kafka-ui（线上 ARM）
KAFKA_CONSOLE_PROVIDER=redpanda

# 前端 Vite 开发代理（npm run dev）与 KAFKA_CONSOLE_PROVIDER 保持一致
VITE_KAFKA_CONSOLE_PROVIDER=redpanda
