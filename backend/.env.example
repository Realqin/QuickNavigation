# 本地开发（MySQL 在 Docker，端口 3309）
DATABASE_URL=mysql+pymysql://quicknav:quicknav123@127.0.0.1:3309/quicknavigation
CORS_ORIGINS=*
GITHUB_WEBHOOK_SECRET=change-me-github-secret
GITHUB_TOKEN=
GITHUB_TOKEN=
# GitLab 私有仓库 diff（你的环境示例）
GITLAB_WEBHOOK_SECRET=change-me-gitlab-secret
GITLAB_TOKEN=
GITLAB_BASE_URL=http://gitlab.bj.uniseas.com.cn
# GitLab / GitHub Webhook 回调基址，须为 GitLab 服务器能访问的地址（不能填 localhost）
# Docker 部署示例：http://192.168.6.127:8080
# 本地开发直连后端：http://192.168.6.127:8000
PUBLIC_WEBHOOK_BASE_URL=
# 数据库结构巡检间隔（秒），默认 300（5 分钟）
SCHEMA_MONITOR_INTERVAL_SECONDS=300
# Kafka 控制台：redpanda（本地）| kafka-ui（线上 ARM）
KAFKA_CONSOLE_PROVIDER=redpanda
# Redpanda Console（Kafka 管理 UI，默认端口 8082）
REDPANDA_PUBLIC_PORT=8082
REDPANDA_KAFKA_HOST=host.docker.internal
# 默认写入 docker/redpanda/data/console-config.yml；kafka-ui 时改为 application.yml
# REDPANDA_CONFIG_PATH=
# REDPANDA_CLUSTERS_MANIFEST_PATH=
REDPANDA_RELOAD_WAIT_SECONDS=3
